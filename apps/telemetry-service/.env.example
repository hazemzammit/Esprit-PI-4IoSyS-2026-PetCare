# ─── Telemetry Service ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=3003

# MongoDB (dedicated telemetry DB)
MONGODB_URI=mongodb://localhost:27017/petcare_telemetry

# Redis
REDIS_URL=redis://localhost:6379

# JWT (same secret as auth-service — for Socket.IO auth)
JWT_SECRET=dev_jwt_secret_change_me

# MQTT broker
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=petcare
MQTT_PASSWORD=petcare_mqtt_2024

# Service URLs
PET_SERVICE_URL=http://localhost:3002
NOTIFICATION_SERVICE_URL=http://localhost:3005

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Dev simulators (set to false in production)
ENABLE_SIMULATORS=true

# Device auth (API key for HTTP telemetry ingestion)
DEVICE_API_KEY=
