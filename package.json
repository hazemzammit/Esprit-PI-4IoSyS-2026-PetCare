{
  "name": "esprit-pi-4iosys-2026-petcare",
  "version": "1.0.0",
  "description": "PetCare IoT - Intelligent Pet Monitoring Platform | PIDEV 4IoSyS | Esprit School of Engineering 2025-2026",
