# ─────────────────────────────────────────────────────────────────────────────
# PetCare IoT — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# This is a sanitized template for the public repository.
# ─────────────────────────────────────────────────────────────────────────────

# ─── General ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Telemetry Service ─────────────────────────────────────────────────────────
TELEMETRY_PORT=3003
MONGODB_URI=mongodb://localhost:27017/petcare_telemetry

# Redis
REDIS_URL=redis://localhost:6379

# MQTT Broker
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=your-mqtt-username-here
MQTT_PASSWORD=your-mqtt-password-here

# JWT Secret (for Socket.IO authentication)
JWT_SECRET=your-jwt-secret-here

# Device Authentication (API key for HTTP telemetry ingestion)
DEVICE_API_KEY=your-device-api-key-here

# Internal Service Authentication (for service-to-service calls)
INTERNAL_API_KEY=your-internal-api-key-here

# Service URLs (for internal communication)
PET_SERVICE_URL=http://localhost:3002
NOTIFICATION_SERVICE_URL=http://localhost:3005

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Socket.IO Configuration
SOCKET_CORS_ORIGIN=http://localhost:5173

# Device Simulators (set to false in production)
ENABLE_SIMULATORS=false

# Telemetry Archival (archive old data to save storage)
ARCHIVAL_ENABLED=false

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_PORT=27017
MONGO_USERNAME=admin
MONGO_PASSWORD=your-mongo-password-here

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here

# ─── MQTT ──────────────────────────────────────────────────────────────────────
MQTT_PORT=1883
MQTT_WS_PORT=9001

# ─── Logging & Observability ───────────────────────────────────────────────────
LOKI_URL=http://localhost:3100
SENTRY_DSN=

# ─── Camera (Pi HLS stream) ───────────────────────────────────────────────────
# Point these to the Raspberry Pi HLS/Snapshot endpoints
CAMERA_STREAM_URL=http://172.20.10.11:8888/hls/index.m3u8
CAMERA_SNAPSHOT_URL=http://172.20.10.11:8888/hls/snapshot.jpg

# ─── Mongo Express (dev UI) ───────────────────────────────────────────────────
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=your-mongo-express-password-here